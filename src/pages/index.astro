<script>
    // Dynamic scripts for the landing page elements
    const doctorModal = document.getElementById("doctor-modal");
    const modalImg = document.getElementById("modal-img") as HTMLImageElement;
    const modalName = document.getElementById("modal-name");
    const modalCreds = document.getElementById("modal-creds");
    const modalBio = document.getElementById("modal-bio");

    function openDoctorModal(card: HTMLElement) {
        if (modalImg && modalName && modalCreds && modalBio && doctorModal) {
            modalImg.src = card.dataset.img || "";
            modalImg.alt = card.dataset.name || "";
            modalName.textContent = card.dataset.name || "";
            modalCreds.textContent = card.dataset.creds || "";
            modalBio.textContent = (card.dataset.bio || "").replace(
                /\\n/g,
                "\n",
            );
            doctorModal.classList.add("open");
            document.body.style.overflow = "hidden";
        }
    }

    function closeDoctorModal() {
        doctorModal?.classList.remove("open");
        document.body.style.overflow = "";
    }

    // Bind triggers to doctor photos
    document.querySelectorAll(".doctor-photo").forEach((photo) => {
        photo.addEventListener("click", () => {
            const card = photo.closest(".doctor-card") as HTMLElement;
            if (card) openDoctorModal(card);
        });
    });

    // Bind triggers to close modal
    document
        .querySelector(".doctor-modal-backdrop")
        ?.addEventListener("click", closeDoctorModal);
    document
        .querySelector(".doctor-modal-close")
        ?.addEventListener("click", closeDoctorModal);

    // Testimonials database
    const testimonials = [
        {
            text: "As always, everyone is friendly and professional. I love, love, love my appointments and the time I spend with the entire team. Awesome and relaxing like being at the spa.",
            author: "— Michelle Davis",
        },
        {
            text: "The best dentist office I've ever been to. The people that work there are friendly and Dr. Richardson was phenomenal. I would tell anybody to go here.",
            author: "— Kirsten Hudson",
        },
        {
            text: "Dental hygienist, Kristy, is fantastic. She is efficient, friendly & does take pride & care when working with a client. Dr. James is the best dentist for me. Again, pride, compassion & care for the client. Totally satisfied with your services.",
            author: "— Sally Lamar",
        },
        {
            text: "Recent check-up and cleaning proved to be worthwhile. All staff greeted me with a warm smile and willingness to do whatever was needed. Cleaning, by Christie, was carefully and painlessly done. Dr. Rubelita James performed the follow-up so nothing was overlooked. I heartily recommend Personal Care Dental to anyone who may be looking for a wonderful Dental Group.",
            author: "— Roger Pool",
