    <!-- ABOUT -->
    <section class="about-section">
        <div class="about-left reveal">
            <div class="about-year">1980</div>
            <div class="about-year-label">Year of Founding</div>
        </div>
        <div class="about-right">
            <div class="section-eyebrow reveal">Our Story</div>
            <h2 class="about-headline reveal reveal-delay-1">
                Where <i>Smiles</i><br />Make Smiles.
            </h2>
            <div class="about-pullquote reveal reveal-delay-2">
                <p>
                    "A privately owned, multi-doctor practice treating patients
                    of all ages — with the warmth of a family practice and the
                    precision of a world-class dental clinic."
                </p>
            </div>
            <p class="about-body reveal reveal-delay-3">
                For over four decades, Personal Care Dental Group has been the
                cornerstone of dental excellence in Raytown, Missouri. We
                believe that every smile tells a story — and we are here to help
                you tell yours beautifully. From routine cleanings to full smile
                transformations, our team delivers personalized care rooted in
                trust, artistry, and the latest techniques.
            </p>
            <div class="about-counters reveal reveal-delay-4">
                <div class="counter-item">
                    <div class="counter-number">
                        <span class="counter-val" data-target="44">0</span><span
                            class="counter-suffix">+</span
                        >
                    </div>
                    <div class="counter-label">Years Serving</div>
                </div>
                <div class="counter-item">
                    <div class="counter-number">
                        <span class="counter-val" data-target="3">0</span>
                    </div>
                    <div class="counter-label">Doctors</div>
                </div>
                <div class="counter-item">
                    <div class="counter-number">
                        <span class="counter-val" data-target="5000">0</span
                        ><span class="counter-suffix">+</span>
                    </div>
                    <div class="counter-label">Happy Patients</div>
                </div>
            </div>
        </div>
    </section>

    <!-- SERVICES -->
    <section class="services-section">
        <div class="services-header reveal">
            <div>
