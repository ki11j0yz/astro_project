                <div class="services-title">Our <i>Services</i></div>
            </div>
        </div>

        <div class="service-row reveal">
            <div class="service-num">01</div>
            <div class="service-name">
                <span class="service-emoji">🦷</span> General Dentistry
            </div>
            <div class="service-desc">
                Comprehensive cleanings, exams, fillings, and preventive care
                for the whole family — all under one roof.
            </div>
            <div class="service-arrow">→</div>
        </div>
        <div class="service-row reveal reveal-delay-1">
            <div class="service-num">02</div>
            <div class="service-name">
                <span class="service-emoji">👶</span> Pediatric Care
