    const textEl = document.querySelector(".testimonial-text");
    const authorEl = document.querySelector(".testimonial-author");
    const dotsContainer = document.querySelector(".testimonial-dots");
    let currentTestimonial = 0;
    let testimonialTimer: ReturnType<typeof setInterval>;

    // Render carousel dots
    if (dotsContainer) {
        testimonials.forEach((_, i) => {
            const dot = document.createElement("div");
            dot.classList.add("testimonial-dot");
            if (i === 0) dot.classList.add("active");
            dot.addEventListener("click", () => {
                clearInterval(testimonialTimer);
                showTestimonial(i);
                testimonialTimer = setInterval(nextTestimonial, 6000);
            });
            dotsContainer.appendChild(dot);
        });
    }

    function showTestimonial(index: number) {
        const dots = document.querySelectorAll(".testimonial-dot");
        if (!textEl || !authorEl) return;

        textEl.classList.remove("active");
        authorEl.classList.remove("active");

        setTimeout(() => {
            textEl.textContent = testimonials[index].text;
            authorEl.textContent = testimonials[index].author;
            currentTestimonial = index;
            dots.forEach((d, i) => d.classList.toggle("active", i === index));

            setTimeout(() => {
                textEl.classList.add("active");
                authorEl.classList.add("active");
            }, 100);
        }, 1200);
    }

    function nextTestimonial() {
        const next = (currentTestimonial + 1) % testimonials.length;
        showTestimonial(next);
    }

    // Start testimonial cycle
    if (textEl && authorEl) {
        textEl.textContent = testimonials[0].text;
        authorEl.textContent = testimonials[0].author;
        textEl.classList.add("active");
        authorEl.classList.add("active");
        testimonialTimer = setInterval(nextTestimonial, 6000);
    }

    // Scroll reveal trigger
    const revealEls = document.querySelectorAll(".reveal");
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((e) => {
                if (e.isIntersecting) {
                    e.target.classList.add("visible");
                    observer.unobserve(e.target);
                }
            });
        },
        { threshold: 0.12 },
    );
    revealEls.forEach((el) => observer.observe(el));

    // Count animations
    function animateCounter(el: HTMLElement) {
        const target = parseInt(el.dataset.target || "0", 10);
        const duration = 1800;
        const start = performance.now();
        const update = (now: number) => {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            const ease = 1 - Math.pow(1 - progress, 3);
            el.textContent = Math.floor(ease * target).toLocaleString();
            if (progress < 1) requestAnimationFrame(update);
        };
        requestAnimationFrame(update);
    }

    const counterObserver = new IntersectionObserver(
        (entries) => {
            entries.forEach((e) => {
                if (e.isIntersecting) {
                    e.target
                        .querySelectorAll(".counter-val")
                        .forEach((el) => animateCounter(el as HTMLElement));
                    counterObserver.unobserve(e.target);
                }
            });
        },
        { threshold: 0.3 },
    );
    document
        .querySelectorAll(".about-counters")
        .forEach((el) => counterObserver.observe(el));
</script>
