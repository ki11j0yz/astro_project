---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Personal Care Dental Group | The Couture">
    <!-- HERO -->
    <section class="hero">
        <div class="hero-image">
            <div class="hero-image-fade"></div>
        </div>
        <div class="hero-line"></div>
        <div class="hero-content">
            <h1 class="hero-title">
                Personal <em>Care</em><br />
                Dental<br />
                Group.
            </h1>
            <p class="hero-tagline">Redefining the Raytown Smile</p>
            <div class="hero-ctas">
                <a href="#" class="btn-primary">Get In Touch</a>
                <a href="#" class="btn-secondary">Our Services</a>
            </div>
            <div class="hero-stats">
                <div class="stat">
                    <div class="stat-value">1980</div>
                    <div class="stat-label">Established</div>
                </div>
                <div class="stat">
                    <div class="stat-value">3</div>
                    <div class="stat-label">Doctors</div>
                </div>
                <div class="stat">
                    <div class="stat-value">4.9<sup>★</sup></div>
                    <div class="stat-label">Patient Rating</div>
                </div>
                <div class="stat">
                    <div class="stat-value">A+</div>
                    <div class="stat-label">BBB Rating</div>
                </div>
            </div>
        </div>
        <div class="hero-label">
            <div class="hero-label-text">"Where Smiles Make Smiles."</div>
            <div class="hero-label-sub">Personal Care Dental Group</div>
        </div>
        <div class="scroll-indicator">
            <div class="scroll-line"></div>
            <span class="scroll-text">Scroll</span>
        </div>
    </section>

    <!-- MARQUEE -->
    <div class="marquee-section">
        <div class="marquee-track" id="marqueeTrack">
            <div class="marquee-item">General Dentistry</div>
            <div class="marquee-item">Pediatric Care</div>
            <div class="marquee-item">Cosmetic Dentistry</div>
            <div class="marquee-item">Invisalign</div>
            <div class="marquee-item">Dental Implants</div>
            <div class="marquee-item">Sleep Apnea</div>
            <div class="marquee-item">Teeth Whitening</div>
            <div class="marquee-item">Restorative Care</div>
            <div class="marquee-item">Nitrous Available</div>
            <div class="marquee-item">All Ages Welcome</div>
            <div class="marquee-item">General Dentistry</div>
            <div class="marquee-item">Pediatric Care</div>
            <div class="marquee-item">Cosmetic Dentistry</div>
            <div class="marquee-item">Invisalign</div>
            <div class="marquee-item">Dental Implants</div>
            <div class="marquee-item">Sleep Apnea</div>
            <div class="marquee-item">Teeth Whitening</div>
            <div class="marquee-item">Restorative Care</div>
            <div class="marquee-item">Nitrous Available</div>
